-- 📩 Enviar webhook
local function SendWebhook(title, color, fields)
    local formatted = {}

    for _, f in pairs(fields) do
        table.insert(formatted, {
            name = f.name,
            value = f.value,
            inline = true
        })
    end

    pcall(function()
        request({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({
                embeds = {{
                    title = title,
                    color = color,
                    fields = formatted,
                    footer = {
                        text = "Tommy Hub Premium 🔥"
                    }
                }}
            })
        })
    end)
end

